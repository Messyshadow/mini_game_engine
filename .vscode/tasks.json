{
    // ========================================================================
    // VSCode 任务配置文件
    // ========================================================================
    //
    // 定义构建任务，可通过以下方式执行：
    // - Ctrl+Shift+B: 运行默认构建任务
    // - Ctrl+Shift+P → "Tasks: Run Task": 选择任务运行
    //
    "version": "2.0.0",
    "tasks": [
        // ====================================================================
        // CMake 配置（生成构建文件）
        // ====================================================================
        {
            "label": "CMake: configure",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-G", "Visual Studio 16 2019",
                "-A", "x64"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "生成Visual Studio 2019项目文件"
        },
        // ====================================================================
        // CMake 配置（VS2022版本）
        // ====================================================================
        {
            "label": "CMake: configure (VS2022)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-G", "Visual Studio 17 2022",
                "-A", "x64"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "生成Visual Studio 2022项目文件"
        },
        // ====================================================================
        // CMake 配置（MinGW Makefiles）
        // ====================================================================
        {
            "label": "CMake: configure (MinGW)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S", "${workspaceFolder}",
                "-B", "${workspaceFolder}/build",
                "-G", "MinGW Makefiles",
                "-DCMAKE_BUILD_TYPE=Debug"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "生成MinGW Makefile"
        },
        // ====================================================================
        // CMake 构建（Debug模式）- 默认构建任务
        // ====================================================================
        {
            "label": "CMake: build",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--config", "Debug"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$msCompile", "$gcc"],
            "detail": "构建Debug版本（默认任务，Ctrl+Shift+B）"
        },
        // ====================================================================
        // CMake 构建（Release模式）
        // ====================================================================
        {
            "label": "CMake: build Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--config", "Release"
            ],
            "group": "build",
            "problemMatcher": ["$msCompile", "$gcc"],
            "detail": "构建Release版本"
        },
        // ====================================================================
        // CMake 清理
        // ====================================================================
        {
            "label": "CMake: clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--target", "clean"
            ],
            "group": "build",
            "problemMatcher": [],
            "detail": "清理构建文件"
        },
        // ====================================================================
        // CMake 重新构建
        // ====================================================================
        {
            "label": "CMake: rebuild",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "${workspaceFolder}/build",
                "--config", "Debug",
                "--clean-first"
            ],
            "group": "build",
            "problemMatcher": ["$msCompile", "$gcc"],
            "detail": "清理后重新构建"
        },
        // ====================================================================
        // 运行 setup.bat（下载依赖）
        // ====================================================================
        {
            "label": "Run setup.bat",
            "type": "shell",
            "command": "${workspaceFolder}/../setup.bat",
            "options": {
                "cwd": "${workspaceFolder}/.."
            },
            "group": "build",
            "problemMatcher": [],
            "detail": "下载GLFW、ImGui等依赖"
        }
    ]
}
