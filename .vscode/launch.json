{
    // ========================================================================
    // VSCode 调试配置文件
    // ========================================================================
    // 
    // 使用方法：
    // 1. 先用CMake构建项目（Debug模式）
    // 2. 按F5或点击调试按钮
    // 3. 从下拉菜单选择要调试的示例
    //
    // 快捷键：
    // - F5: 开始调试
    // - F9: 切换断点
    // - F10: 单步跳过
    // - F11: 单步进入
    // - Shift+F11: 单步跳出
    // - Shift+F5: 停止调试
    //
    "version": "0.2.0",
    "configurations": [
        // ====================================================================
        // 示例01：基础窗口与向量数学
        // ====================================================================
        {
            "name": "01 - Window & Vector Math",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/01_window.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/Debug",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "CMake: build"
        },
