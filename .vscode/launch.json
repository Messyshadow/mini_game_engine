        // [GDB] 示例01 - 使用GDB调试（MinGW用户）
        // ====================================================================
        {
            "name": "[GDB] 01 - Window",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/Debug/01_window.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}/build/Debug",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
